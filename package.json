{
  "name": "theledger",
  "private": true,
  "packageManager": "pnpm@10.23.0",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "biome check .",
    "lint:staged": "biome check --staged --no-errors-on-unmatched",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "pnpm --filter @theledger/core build",
    "precommit": "pnpm lint:staged && pnpm typecheck",
    "prepare": "husky"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "husky": "^9",
    "turbo": "^2"
  }
}
